# --- DARSI RS UNS CORE CONFIGURATION ---
APP_NAME="DARSI RS UNS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api.darsi-anda.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# --- LOGGING ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- DATABASE (POSTGRESQL FOR HIS INTEGRATION) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=darsi_db
DB_USERNAME=postgres
DB_PASSWORD=

# --- SESSION & QUEUE ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- REDIS (OPTIONAL) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- AI ENGINE CONFIGURATION (LLAMA 3.3 VIA GROQ) ---
GROQ_API_KEY=your_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- AGENT INTERFACE (OPENCLAW INTEGRATION) ---
OPENCLAW_ENDPOINT=http://localhost:18789
OPENCLAW_TOKEN=your_secret_token

# --- MAIL CONFIGURATION (FOR NOTIFICATIONS) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@darsi-rsuns.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- FRONTEND SINKRONISASI ---
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api"