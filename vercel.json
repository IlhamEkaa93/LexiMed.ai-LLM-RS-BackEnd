{
  "version": 2,
  "framework": null,
  "buildCommand": "mkdir -p public && touch public/index.html",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.6.2" }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
